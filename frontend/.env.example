# Frontend env vars consumed by Vite at build time.
# Copy to `.env.local` and edit as needed; .env.local is gitignored.

# Override the API base URL. Default: "/api/v1" (same-origin, recommended).
# Set this only if the dashboard talks to a backend on a different origin.
# VITE_API_BASE=/api/v1

# Pre-bake the X-API-Key header at build time so the dashboard mutates without
# the user pasting the key into the Admin settings panel. Useful for scripted
# kiosk-style deploys; leave unset for normal local use.
# VITE_API_KEY=
